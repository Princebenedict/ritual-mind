# Ritual Mind contracts environment.
# Copy to .env and fill in before deploying. Never commit the real .env.

# Chain connection.
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws
RITUAL_VERIFIER_URL=https://rpc.ritualfoundation.org/api/verify

# Deployer key. This is the funded wallet that broadcasts the deployment.
# The deployer address is derived from this key. It is never hardcoded in source.
# Replace the placeholder with your funded key for DEPLOYER_WALLET_ADDRESS_HERE.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_FOR_DEPLOYER_WALLET_ADDRESS_HERE

# Optional. If set, the agent is authorized on the oracle during deployment.
# AGENT_ADDRESS is the enclave controlled address that runs the persistent agent.
# AGENT_TEE_KEY binds that agent to its attestation identity.
AGENT_ADDRESS=
AGENT_TEE_KEY=
