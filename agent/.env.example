# Ritual Mind agent environment. Copy to .env and fill in. Never commit the real .env.

# Chain connection.
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws

# Agent key. This is the enclave held key that the oracle authorizes. It is a distinct
# key from the deployer. Fund it so the agent can pay its own gas.
AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY

# Deployed Ritual Mind contract addresses from the deploy script output.
SCORE_ORACLE_ADDRESS=0xYOUR_SCORE_ORACLE_ADDRESS
WALLET_REGISTRY_ADDRESS=0xYOUR_WALLET_REGISTRY_ADDRESS
PROJECT_REGISTRY_ADDRESS=0xYOUR_PROJECT_REGISTRY_ADDRESS
ACTIVITY_EMITTER_ADDRESS=0xYOUR_ACTIVITY_EMITTER_ADDRESS

# Social. Bearer token is encrypted to the executor and decrypted only inside the TEE.
TWITTER_BEARER_TOKEN=
TWITTER_SEARCH_TERMS=ritual chain,ritualfnd,#BuildOnRitual

# Explorer API used for the on chain scan. Blockscout v2 shape by default.
EXPLORER_API_URL=https://explorer.ritualfoundation.org/api

# IPFS pinning for the daily digest. Optional. Encrypted to the executor.
PINATA_JWT=
PINATA_API_URL=https://api.pinata.cloud

# Cycle behavior.
CYCLE_INTERVAL_MS=21600000
LOW_FUNDS_THRESHOLD_WEI=500000000000000000
DEPOSIT_AMOUNT_WEI=2000000000000000000
LOCK_DURATION_BLOCKS=100000
MAX_BATCH=100

# Set to 1 for verbose debug logging.
DEBUG=0
