{
  "name": "@ritualmind/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Persistent TEE agent for Ritual Mind. Runs the six hour scoring cycle.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "cycle": "tsx src/index.ts --once"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "eciesjs": "^0.4.11",
    "viem": "^2.21.45"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
