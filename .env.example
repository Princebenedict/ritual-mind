# Ritual Mind, consolidated environment reference.
#
# Each workspace has its own env file. This file lists every variable in one place. Copy
# the relevant values into contracts/.env, agent/.env, and frontend/.env.local.
#
# The deployer wallet is never hardcoded in source. Insert your funded wallet in place of
# DEPLOYER_WALLET_ADDRESS_HERE and provide its private key below before deploying.

# ===== Chain =====
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws
RITUAL_VERIFIER_URL=https://rpc.ritualfoundation.org/api/verify

# ===== Deployer (contracts/.env) =====
# Funded wallet that broadcasts the deployment. Its address is DEPLOYER_WALLET_ADDRESS_HERE.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_FOR_DEPLOYER_WALLET_ADDRESS_HERE

# ===== Agent (agent/.env) =====
# Enclave held agent key, distinct from the deployer. Authorized on the oracle.
AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY
# Set at deploy time to authorize the agent in the same run, or authorize later.
AGENT_ADDRESS=
AGENT_TEE_KEY=
TWITTER_BEARER_TOKEN=
TWITTER_SEARCH_TERMS=ritual chain,ritualfnd,#BuildOnRitual
EXPLORER_API_URL=https://explorer.ritualfoundation.org/api
PINATA_JWT=
CYCLE_INTERVAL_MS=21600000

# ===== Deployed Ritual Mind addresses (fill after deployment) =====
# Agent (unprefixed) and frontend (NEXT_PUBLIC prefixed) both need these.
ACTIVITY_EMITTER_ADDRESS=
WALLET_REGISTRY_ADDRESS=
PROJECT_REGISTRY_ADDRESS=
SCORE_ORACLE_ADDRESS=

NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws
NEXT_PUBLIC_ACTIVITY_EMITTER=
NEXT_PUBLIC_WALLET_REGISTRY=
NEXT_PUBLIC_PROJECT_REGISTRY=
NEXT_PUBLIC_BADGE_NFT=
NEXT_PUBLIC_SCORE_ORACLE=
