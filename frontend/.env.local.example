# Ritual Mind frontend environment. Copy to .env.local. Public values are exposed to the
# browser. The app runs on demo data until the contract addresses are set.

NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws

# Deployed Ritual Mind contract addresses from the deploy script output.
NEXT_PUBLIC_ACTIVITY_EMITTER=
NEXT_PUBLIC_WALLET_REGISTRY=
NEXT_PUBLIC_PROJECT_REGISTRY=
NEXT_PUBLIC_BADGE_NFT=
NEXT_PUBLIC_SCORE_ORACLE=
